{
    "name": "backend",
    "version": "1.0.0",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "build": "npx tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
        "start": "node ./dist/index.js",
        "start-no-pretty": "node ./dist/index.js | less",
        "migration:generate": "node ./src/db/scripts/migrationGenerate.js",
        "migration:run": "typeorm migration:run -d ./dist/db/data-source.js",
        "migration:revert": "node ./dist/db/scripts/migrationRevert.js",
        "entity:create": "node ./dist/db/scripts/entityCreate.js",
        "db:seed": "node ./dist/db/fixturesAndSeeds/seedDB.js",
        "db:seed:foods": "node ./dist/db/fixturesAndSeeds/seedDBFoods.js",
        "db:seed:roles": "node ./dist/db/fixtures/roles.db.seed.js",
        "db:seed2.0": "npm run db:seed:foods && npm run db:seed:roles",
        "build-and-seed": "npm run build && npm run db:seed2.0",
        "run:files": "node ./run-files.js"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "@fastify/autoload": "^6.3.1",
        "@fastify/cookie": "^11.0.2",
        "@fastify/cors": "^11.2.0",
        "@fastify/error": "^4.2.0",
        "@fastify/jwt": "^9.1.0",
        "@fastify/rate-limit": "^10.3.0",
        "@fastify/redis": "^7.2.0",
        "bcrypt": "^6.0.0",
        "chalk": "^5.6.0",
        "close-with-grace": "^2.2.0",
        "dotenv": "^17.0.1",
        "fastify": "^5.4.0",
        "fastify-plugin": "^5.1.0",
        "pg": "^8.16.3",
        "pino-pretty": "^13.0.0",
        "reflect-metadata": "^0.2.2",
        "resend": "^6.9.4",
        "typeorm": "^0.3.25",
        "typeorm-fastify-plugin": "^3.0.0"
    },
    "devDependencies": {
        "@tsconfig/node22": "^22.0.2",
        "@types/bcrypt": "^6.0.0",
        "@types/node": "^24.0.10",
        "@types/pino": "^7.0.4",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
        "typescript": "^5.8.3"
    }
